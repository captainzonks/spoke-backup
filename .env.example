# ==============================================================================
# BACKUP MODULE - ENVIRONMENT VARIABLES
# ==============================================================================
# Description: Module-specific environment defaults for spoke-backup
# Author: Matt Barham
# Created: 2026-04-28
# Modified: 2026-05-06
# Version: 1.1.0
# Host: Your Server
# ==============================================================================
# Type: Template
# Security Level: LOW - placeholder bucket name and image tags only
# Component: module: backup
# ==============================================================================
# Note: This file provides module defaults. Hub base.env variables are merged
#       automatically by Spoke. Site-specific overrides go in modules.yml.
# ==============================================================================

#==========================================================================
# CONTAINER IMAGES
#==========================================================================

# Kopia backup engine (server mode + UI)
# https://github.com/kopia/kopia/releases
KOPIA_IMAGE=kopia/kopia:0.22.3

# Custom orchestrator (alpine + postgres-client + kopia client + cron)
BACKUP_ORCHESTRATOR_IMAGE=spoke/backup-orchestrator:1.0.0

#==========================================================================
# NETWORK
#==========================================================================

# Static IPs on troxy (192.168.35.0/24)
KOPIA_IP=192.168.35.113
BACKUP_ORCHESTRATOR_IP=192.168.35.114

# Subdomain for Kopia web UI (behind Traefik + authentik forward-auth)
KOPIA_SUBDOMAIN=kopia

#==========================================================================
# KOPIA SERVER
#==========================================================================

# Username for Kopia server API auth (orchestrator -> kopia)
# Password lives in secrets/backup/kopia_server_password
KOPIA_SERVER_USERNAME=spoke-orchestrator

#==========================================================================
# KOPIA REPOSITORY (Backblaze B2)
#==========================================================================

# B2 bucket name (override in modules.yml for your site)
KOPIA_REPO_BUCKET=example-backup-v1

# B2 S3-compatible endpoint (matches bucket region)
KOPIA_REPO_ENDPOINT=s3.us-west-004.backblazeb2.com

# B2 region
KOPIA_REPO_REGION=us-west-004

# Path prefix inside bucket (allows multiple Spoke instances per bucket)
KOPIA_REPO_PREFIX=spoke/

#==========================================================================
# BACKUP STAGING
#==========================================================================

# Where orchestrator writes Postgres dumps before Kopia snapshots them
# Lives under appdata so it persists between runs (Kopia dedup benefits)
BACKUP_STAGING_DIR=/var/backups/spoke

#==========================================================================
# RETENTION POLICY (GFS)
#==========================================================================

BACKUP_RETENTION_DAILY=10
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=12
BACKUP_RETENTION_YEARLY=3

#==========================================================================
# SCHEDULE (24h, server local time)
#==========================================================================

# Hour to run Postgres dumps (HH, 0-23)
BACKUP_PG_DUMP_HOUR=3

# Hour to run Kopia snapshot (must be after pg dump completes)
BACKUP_SNAPSHOT_HOUR=4

# Day of week for repository verification (0=Sunday, 6=Saturday)
BACKUP_VERIFY_DAY=0

#==========================================================================
# NOTIFICATIONS
#==========================================================================

# Email address to notify on backup runs
BACKUP_NOTIFY_TO=admin@example.com

# Sender identity (must match mail-relay allowlist)
BACKUP_NOTIFY_FROM=services@example.com

# When to send notifications: always | failure | never
BACKUP_NOTIFY_ON=always

# Mail relay HTTP endpoint (in-cluster)
MAIL_RELAY_URL=http://mail-relay:8000/send

#==========================================================================
# POSTGRES CLUSTERS
#==========================================================================

# Space-separated name:host pairs for clusters to pg_dump.
# Secret for each cluster must be at: secrets/backup/postgres_<name>_backup_password
# and declared in docker-compose.override.yml.
# Example with multiple clusters: "hub:postgres-hub app:app-postgres"
BACKUP_PG_CLUSTERS=hub:postgres-hub

#==========================================================================
# EXTRA BACKUP SOURCES
#==========================================================================

# Space-separated list of additional paths to snapshot beyond the core four
# (secrets, shared-env, appdata, staging). Each path must also be mounted
# as a read-only volume in docker-compose.override.yml.
# Example: "/sources/photos /sources/documents"
BACKUP_EXTRA_SOURCES=
